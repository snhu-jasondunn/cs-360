<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/LoginFragment">

    <fragment
        android:id="@+id/LoginFragment"
        android:name="com.snhu.inventoryplus.Login"
        android:label="@string/app_name"
        tools:layout="@layout/login">

        <action
            android:id="@+id/action_LoginFragment_to_InventoryFragment"
            app:destination="@id/InventoryFragment"
            app:popUpTo="@id/LoginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/InventoryFragment"
        android:name="com.snhu.inventoryplus.InventoryDashboard"
        android:label="@string/inventory_title"
        tools:layout="@layout/inventory_dashboard">

        <action
            android:id="@+id/action_InventoryFragment_to_SMSNotificationsFragment"
            app:destination="@id/SMSNotificationsFragment" />
        <action
            android:id="@+id/action_InventoryFragment_to_AddInventoryFragment"
            app:destination="@id/AddInventoryFragment" />
        <action
            android:id="@+id/action_InventoryFragment_to_EditInventoryFragment"
            app:destination="@id/EditInventoryFragment" />
    </fragment>
    <fragment
        android:id="@+id/AddInventoryFragment"
        android:name="com.snhu.inventoryplus.AddInventory"
        android:label="@string/add_inventory_title"
        tools:layout="@layout/add_inventory" />
    <fragment
        android:id="@+id/EditInventoryFragment"
        android:name="com.snhu.inventoryplus.EditInventory"
        android:label="@string/edit_inventory_title"
        tools:layout="@layout/edit_inventory">

        <argument
            android:name="itemId"
            app:argType="long"
            android:defaultValue="-1L" />
    </fragment>
    <fragment
        android:id="@+id/SMSNotificationsFragment"
        android:name="com.snhu.inventoryplus.SMSNotifications"
        android:label="@string/action_settings"
        tools:layout="@layout/sms_notifications">

        <action
            android:id="@+id/action_SMSNotificationsFragment_to_InventoryFragment"
            app:destination="@id/InventoryFragment" />
    </fragment>
</navigation>
